{
  "name": "copilotline-demo-remotion",
  "version": "1.0.0",
  "private": true,
  "description": "Remotion project that renders copilotline README demo GIFs.",
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "render:gif:statusline": "remotion render src/index.ts statusline ../demo-statusline.gif --codec=gif",
    "render:gif:cli": "remotion render src/index.ts cli ../demo-cli.gif --codec=gif",
    "render:gif:all": "npm run render:gif:statusline && npm run render:gif:cli",
    "render:mp4:statusline": "remotion render src/index.ts statusline ../demo-statusline.mp4 --width=1280 --height=240",
    "render:mp4:cli": "remotion render src/index.ts cli ../demo-cli.mp4 --width=1280 --height=680"
  },
  "dependencies": {
    "@remotion/bundler": "4.0.392",
    "@remotion/cli": "4.0.392",
    "@remotion/renderer": "4.0.392",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "remotion": "4.0.468"
  },
  "devDependencies": {
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.2",
    "typescript": "5.7.2",
    "webpack": "^5.106.2"
  },
  "overrides": {
    "webpack": "^5.106.2",
    "fast-uri": ">=3.1.2",
    "ws": ">=8.20.1"
  }
}
